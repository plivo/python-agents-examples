# Deepgram (STT)
DEEPGRAM_API_KEY=

# Google Gemini (LLM)
GOOGLE_API_KEY=

# xAI TTS
XAI_TTS_API_KEY=

# Voice and scenario selection
# Voices: Ara, Eve, Rex, Sal, Leo
# Scenarios: storytelling, counselor, travel, casual, news, multilingual, expressive
XAI_VOICE=Ara
SCENARIO=storytelling

# Plivo telephony
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=
PLIVO_TO_NUMBER=

# Smart Turn detection (seconds of silence before committing turn)
SMART_TURN_STOP_SECS=3.0

# Dashboard port
DASHBOARD_PORT=8080
